# Copy this to .env (which is gitignored) and edit the values.
# Used by `pnpm start` (local) and `docker compose` (deployment + Caddy TLS).

# The single login for the vault:
SHARE_USER=admin
SHARE_PASS=change-me-please

# Secret used to sign the session cookie. Generate one with:
#   openssl rand -hex 32
# If left blank, a random secret is used and everyone is logged out on restart.
SESSION_SECRET=

# ── Local (pnpm) only ──────────────────────────────────────────────
# Listen port and bind address for `pnpm start`.
PORT=8000
HOST=0.0.0.0
# Folder to expose, relative to the repo root.
SHARE_DIR=shared

# ── Docker ─────────────────────────────────────────────────────────
# Host folder to expose inside the container (mounted at /data).
# Point at your media/files dir on the Proxmox host, e.g. /mnt/tank/library.
# Must be readable/writable by uid 1000. To test with the repo's PDFs: ./books
DATA_DIR=./data

# ── Docker + Caddy TLS ─────────────────────────────────────────────
# Host ports Caddy publishes.
HTTP_PORT=80
HTTPS_PORT=443
# What Caddy serves on:
#   leave as ":443" for LAN access by IP using Caddy's internal CA (default), or
#   set a public domain (e.g. vault.example.com) to auto-provision Let's Encrypt.
SITE_ADDRESS=:443
# Required ONLY for Let's Encrypt (public domain). Leave blank for LAN/internal CA.
TLS_EMAIL=
