# share-net reverse proxy with automatic TLS.
#
# LAN access by IP (typical): set SITE_ADDRESS and DEFAULT_SNI to the host IP in
# .env (e.g. 192.168.15.39). Caddy's internal CA mints a cert for that IP; the
# DEFAULT_SNI is required because browsers omit SNI for a bare-IP URL, and
# without it Caddy has no default cert to present and the handshake fails.
# Browsers warn until you trust Caddy's root CA (see README); traffic is
# encrypted either way.
#
# Public domain + Let's Encrypt: set SITE_ADDRESS=vault.example.com and
# TLS_EMAIL=you@example.com in .env (ports 80/443 must be reachable from the
# internet). DEFAULT_SNI can stay unset — browsers send SNI for hostnames.

{
	# cert to serve when a client sends no SNI (bare-IP access). harmless for
	# domain setups. defaults to localhost so the directive always has one arg.
	default_sni {$DEFAULT_SNI:localhost}
}

{$SITE_ADDRESS::443} {
	# only compress text-like responses; never touch pdfs/binaries so downloads
	# keep an intact Content-Length + range support (pdf.js streaming relies on it).
	encode zstd gzip {
		match {
			header Content-Type text/*
			header Content-Type application/json*
			header Content-Type application/javascript*
			header Content-Type image/svg+xml*
		}
	}

	# Streams large downloads/uploads through; Caddy imposes no body-size cap.
	reverse_proxy share-net:8000

	# Empty TLS_EMAIL -> internal CA; an email -> managed Let's Encrypt certs.
	tls {$TLS_EMAIL:internal}
}

# Send plain HTTP to HTTPS. (ACME HTTP-01 challenges are still answered here
# automatically at a higher priority, so Let's Encrypt keeps working.)
:80 {
	redir https://{host}{uri} permanent
}
